{
  "background": "#f3ecd8",
  "paper": {
    "enabled": true,
    "opacity": 0.14
  },
  "defaultLayer": {
    "fill": "none",
    "stroke": "#332f29",
    "strokeWidth": 1.2,
    "opacity": 1
  },
  "layers": [
    {
      "id": "water",
      "zIndex": 10,
      "match": {
        "kind": ["water", "river", "lake"]
      },
      "geometry": ["Polygon", "MultiPolygon", "LineString", "MultiLineString"],
      "fill": "#d9e7df",
      "stroke": "#2e5f64",
      "strokeWidth": 1.8,
      "texture": "waves",
      "sketch": {
        "enabled": true,
        "copies": 2,
        "jitter": 0.5,
        "opacity": 0.42
      }
    },
    {
      "id": "park",
      "zIndex": 20,
      "match": {
        "kind": ["park", "green", "forest", "garden"]
      },
      "geometry": ["Polygon", "MultiPolygon"],
      "fill": "#dfe7c5",
      "stroke": "#3f6040",
      "strokeWidth": 1.3,
      "texture": "leaf-dots",
      "sketch": {
        "enabled": true,
        "copies": 2,
        "jitter": 0.55,
        "opacity": 0.35
      }
    },
    {
      "id": "building",
      "zIndex": 30,
      "match": {
        "kind": ["building", "poi-building"]
      },
      "geometry": ["Polygon", "MultiPolygon"],
      "fill": "#d8c29d",
      "stroke": "#3b3026",
      "strokeWidth": 1.1,
      "texture": "hatch",
      "sketch": {
        "enabled": true,
        "copies": 1,
        "jitter": 0.35,
        "opacity": 0.45
      }
    },
    {
      "id": "path",
      "zIndex": 40,
      "match": {
        "kind": ["path", "footway", "trail"]
      },
      "geometry": ["LineString", "MultiLineString"],
      "casing": {
        "stroke": "#f8f1df",
        "strokeWidth": 5.2
      },
      "stroke": "#4f4538",
      "strokeWidth": 2,
      "lineCap": "round",
      "lineJoin": "round",
      "sketch": {
        "enabled": true,
        "copies": 3,
        "jitter": 0.45,
        "opacity": 0.35
      }
    },
    {
      "id": "road",
      "zIndex": 50,
      "match": {
        "kind": ["road", "street", "service"]
      },
      "geometry": ["LineString", "MultiLineString"],
      "casing": {
        "stroke": "#f8f1df",
        "strokeWidth": 7
      },
      "stroke": "#2f2b25",
      "strokeWidth": 2.8,
      "lineCap": "round",
      "lineJoin": "round",
      "sketch": {
        "enabled": true,
        "copies": 2,
        "jitter": 0.5,
        "opacity": 0.45
      }
    }
  ]
}
