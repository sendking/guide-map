{
  "background": "#f7efd8",
  "paper": {
    "enabled": true,
    "opacity": 0.16
  },
  "defaultLayer": {
    "fill": "none",
    "stroke": "#7b6142",
    "strokeWidth": 1.5,
    "opacity": 1
  },
  "layers": [
    {
      "id": "water",
      "zIndex": 10,
      "match": {
        "kind": ["water", "river", "lake"]
      },
      "geometry": ["Polygon", "MultiPolygon", "LineString", "MultiLineString"],
      "fill": "#b9d7d3",
      "stroke": "#5f9da0",
      "strokeWidth": 1.8,
      "texture": "waves",
      "sketch": {
        "enabled": true,
        "copies": 2,
        "jitter": 0.55,
        "opacity": 0.24
      }
    },
    {
      "id": "park",
      "zIndex": 20,
      "match": {
        "kind": ["park", "green", "forest", "garden"]
      },
      "geometry": ["Polygon", "MultiPolygon"],
      "fill": "#cfe1b6",
      "stroke": "#7fa56d",
      "strokeWidth": 1.2,
      "texture": "leaf-dots",
      "sketch": {
        "enabled": true,
        "copies": 2,
        "jitter": 0.55,
        "opacity": 0.2
      }
    },
    {
      "id": "building",
      "zIndex": 30,
      "match": {
        "kind": ["building", "poi-building"]
      },
      "geometry": ["Polygon", "MultiPolygon"],
      "fill": "#e2c89f",
      "stroke": "#9d7753",
      "strokeWidth": 1,
      "texture": "hatch",
      "sketch": {
        "enabled": true,
        "copies": 1,
        "jitter": 0.35,
        "opacity": 0.24
      }
    },
    {
      "id": "path",
      "zIndex": 60,
      "match": {
        "kind": ["path", "footway", "trail"]
      },
      "geometry": ["LineString", "MultiLineString"],
      "casing": {
        "stroke": "#fffdf2",
        "strokeWidth": 7.2
      },
      "stroke": "#a87546",
      "strokeWidth": 2.8,
      "lineCap": "round",
      "lineJoin": "round",
      "sketch": {
        "enabled": true,
        "copies": 3,
        "jitter": 0.42,
        "opacity": 0.32
      }
    },
    {
      "id": "road",
      "zIndex": 70,
      "match": {
        "kind": ["road", "street", "service"]
      },
      "geometry": ["LineString", "MultiLineString"],
      "casing": {
        "stroke": "#fff6df",
        "strokeWidth": 8
      },
      "stroke": "#d79a58",
      "strokeWidth": 3.6,
      "lineCap": "round",
      "lineJoin": "round",
      "sketch": {
        "enabled": true,
        "copies": 3,
        "jitter": 0.55,
        "opacity": 0.24
      }
    }
  ]
}
